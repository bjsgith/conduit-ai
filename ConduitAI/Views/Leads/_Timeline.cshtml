@model IReadOnlyList<LeadInteraction>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="big">No interactions yet</div>
        <div>Log a call, email, or tour to start the timeline.</div>
    </div>
}
else
{
    <ul class="timeline">
        @foreach (var item in Model)
        {
            <li>
                <div class="tl-top">
                    <span class="tl-type">@DisplayText.Humanize(item.InteractionType)</span>
                    <span class="tl-when">@item.OccurredAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                    <form method="post" asp-controller="Interactions" asp-action="Delete" asp-route-id="@item.Id"
                          class="tl-del js-confirm" data-confirm="Remove this interaction?">
                        <button type="submit" class="btn btn-sm btn-ghost" title="Remove">✕</button>
                    </form>
                </div>
                <div class="tl-notes">@item.Notes</div>
            </li>
        }
    </ul>
}
