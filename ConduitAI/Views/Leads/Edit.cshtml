@model LeadFormViewModel
@{
    ViewData["Title"] = "Edit Lead";
}

<div class="page-head">
    <h1>Edit Lead</h1>
    <a class="btn btn-ghost" asp-controller="Leads" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
</div>

<section class="card">
    <div class="card-body">
        <form method="post" asp-controller="Leads" asp-action="Edit" asp-route-id="@Model.Id">
            @await Html.PartialAsync("_LeadForm", Model)
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a class="btn btn-ghost" asp-controller="Leads" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
