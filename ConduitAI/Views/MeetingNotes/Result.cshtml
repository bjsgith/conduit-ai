@model MeetingNotesResultViewModel
@{
    ViewData["Title"] = "Meeting Notes Result";
    var note = Model.Note;
}

<div class="page-head">
    <div>
        <h1>Structured Meeting Notes</h1>
        <span class="count-chip">Generated @note.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")@(string.IsNullOrWhiteSpace(note.ModelName) ? "" : $" · {note.ModelName}")</span>
    </div>
    <a class="btn btn-ghost" asp-controller="MeetingNotes" asp-action="Create">Analyze More Notes</a>
</div>

<div class="grid grid-2">
    <section class="card">
        <div class="card-head"><h3>Summary &amp; Insights</h3></div>
        <div class="card-body">
            <p class="ai-summary">@note.StructuredSummary</p>

            @if (note.KeyFacts.Count > 0)
            {
                <div class="section-title">Key facts</div>
                <ul class="facts" style="margin-bottom:16px;">
                    @foreach (var fact in note.KeyFacts)
                    {
                        <li>@fact</li>
                    }
                </ul>
            }

            @if (note.Risks.Count > 0)
            {
                <div class="section-title">Risks</div>
                <ul class="facts risks" style="margin-bottom:16px;">
                    @foreach (var risk in note.Risks)
                    {
                        <li>@risk</li>
                    }
                </ul>
            }

            <div class="ai-next">
                <b>Recommended next action</b>
                @note.RecommendedNextAction
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-head"><h3>Original Notes</h3></div>
        <div class="card-body">
            <p class="tl-notes">@note.RawNotes</p>
        </div>
    </section>
</div>
